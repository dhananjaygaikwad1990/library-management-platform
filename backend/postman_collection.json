{
  "info": {
    "name": "Library HTTP API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the FastAPI HTTP endpoints in app/api.py."
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "host",
      "value": "localhost",
      "type": "string"
    },
    {
      "key": "port",
      "value": "8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_email",
      "value": "admin1@example.com",
      "type": "string"
    },
    {
      "key": "admin_password",
      "value": "AdminPass1!",
      "type": "string"
    },
    {
      "key": "student_email",
      "value": "student1@example.com",
      "type": "string"
    },
    {
      "key": "student_password",
      "value": "StudentPass1!",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://{{host}}:{{port}}/health",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Get Access Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
        },
        "url": {
          "raw": "http://{{host}}:{{port}}/token",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "token"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Token returned\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.collectionVariables.set(\"access_token\", data.access_token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create Author",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Austen\",\n  \"biography\": \"English novelist known primarily for her six major novels.\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "http://{{host}}:{{port}}/authors",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "authors"
          ]
        }
      }
    },
    {
      "name": "Create Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"author_id\": 1,\n  \"isbn\": \"9780141439518\",\n  \"title\": \"Pride and Prejudice\",\n  \"category\": \"Classic Fiction\",\n  \"publisher\": \"Penguin Classics\",\n  \"publish_year\": 1813,\n  \"language\": \"English\",\n  \"pages\": 279\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "http://{{host}}:{{port}}/books",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "books"
          ]
        }
      }
    },
    {
      "name": "Create Book Copy",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"book_id\": 1,\n  \"barcode\": \"BCP-0001\",\n  \"shelf_location\": \"Aisle 3, Shelf B\",\n  \"status\": \"available\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "http://{{host}}:{{port}}/copies",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "copies"
          ]
        }
      }
    },
    {
      "name": "Create Member",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 Main Street\",\n  \"membership_date\": \"2026-07-18\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "http://{{host}}:{{port}}/members",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "members"
          ]
        }
      }
    },
    {
      "name": "Borrow Book Copy",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"copy_id\": 1,\n  \"member_id\": 1,\n  \"borrow_date\": \"2026-07-18\",\n  \"due_date\": \"2026-08-18\",\n  \"remarks\": \"First borrow\"\n}"
        },
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "http://{{host}}:{{port}}/borrow",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "borrow"
          ]
        }
      }
    },
    {
      "name": "List Books",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "header": [],
        "url": {
          "raw": "http://{{host}}:{{port}}/books",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "books"
          ]
        }
      }
    },
    {
      "name": "Get Book By ID",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "header": [],
        "url": {
          "raw": "http://{{host}}:{{port}}/books/{{book_id}}",
          "protocol": "http",
          "host": [
            "{{host}}"
          ],
          "port": "{{port}}",
          "path": [
            "books",
            "{{book_id}}"
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Set the book_id variable before sending the request"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
